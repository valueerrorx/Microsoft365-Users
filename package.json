{
  "name": "microsoft365-users",
  "version": "2.0.5",
  "description": "MS-365 User Management Dashboard",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --publish never"
  },
  "author": "Thomas Michael Weissel <valueerror@gmail.com>",
  "license": "ISC",
  "build": {
    "appId": "eu.life-edu.microsoft365users",
    "productName": "Microsoft365Users",
    "icon": "icon.png",
    "publish": null,
    "files": [
      "dist/**/*",
      "index.js",
      "preload.js",
      "scripts/**/*",
      "node_modules/**/*",
      "icon.png"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png",
      "category": "Utility",
      "synopsis": "Microsoft 365 Benutzer- und Lizenzverwaltung",
      "description": "MS-365 User Management Dashboard",
      "maintainer": "Thomas Michael Weissel <valueerror@gmail.com>",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "desktop": {
        "StartupWMClass": "microsoft365-users"
      }
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}",
      "publisherName": "Thomas Michael Weissel <valueerror@gmail.com>"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg"
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "icon.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@electron/universal": "^2.0.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^38.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.11.3",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  }
}
