{
  "name": "microsoft365-manager",
  "version": "2.2.10",
  "description": "MS-365 User Management Dashboard",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --publish never",
    "build:test": "npm run build:renderer && electron-builder --linux dir --publish never",
    "build:linux": "npm run build:renderer && electron-builder --linux --publish never",
    "build:mac:arm64": "npm run build:renderer && electron-builder --mac --arm64 --publish never"
  },
  "author": "Thomas Michael Weissel <valueerror@gmail.com>",
  "license": "GPL-3.0-or-later",
  "build": {
    "appId": "eu.life-edu.microsoft365manager",
    "productName": "Microsoft365Manager",
    "icon": "icon.png",
    "publish": null,
    "files": [
      "dist/**/*",
      "index.js",
      "graph-device-auth.mjs",
      "scheduled-directory-roles.mjs",
      "preload.js",
      "scripts/**/*",
      "config/**/*",
      "node_modules/**/*",
      "icon.png",
      "icon-small.png"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png",
      "category": "Utility",
      "synopsis": "Microsoft 365 Benutzer- und Lizenzverwaltung",
      "description": "MS-365 User Management Dashboard",
      "maintainer": "Thomas Michael Weissel <valueerror@gmail.com>",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "desktop": {
        "entry": {
          "StartupWMClass": "microsoft365-manager"
        }
      }
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "portable": {
      "useZip": true
    },
    "msi": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg"
      ],
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "icon.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@electron/universal": "^3.0.4",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.11.3",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  }
}
